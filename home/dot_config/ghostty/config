# Ghostty terminal config.
#
# Notes:
# - Ghostty doesn't expose every tab bar placement/style knob, so the
#   previous bottom powerline tab bar setup is not represented 1:1.
# - Ghostty scrollback is sized in bytes rather than lines.
# - Forcing X11 is typically handled at launch time on GTK systems rather than
#   with a Ghostty config key.

font-family = JetBrainsMono Nerd Font Mono
font-size = 16

shell-integration = detect

copy-on-select = clipboard
scrollback-limit = 16777216
window-show-tab-bar = auto
maximize = true

keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard

foreground = cdd6f4
background = 1e1e2e
selection-foreground = 1e1e2e
selection-background = f5e0dc

cursor-color = f5e0dc
cursor-text = 1e1e2e

palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#bac2de
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#f5c2e7
palette = 14=#94e2d5
palette = 15=#a6adc8
