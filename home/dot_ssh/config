Host *
  ForwardAgent yes
  IdentityAgent ~/.ssh/agent.sock
  IdentitiesOnly yes
  AddKeysToAgent Yes
  StrictHostKeyChecking accept-new
  Compression no
  ServerAliveInterval 0
  ServerAliveCountMax 3
Host github.com
  User git
  HostName github.com
  IdentityFile ~/.ssh/id_ed25519_sk_rk_YubiKey-USB-A
  IdentityFile ~/.ssh/id_ed25519_sk_rk_Yubikey-USB-C
Host gitea.com
  User git
  HostName gitea.com
  IdentityFile ~/.ssh/id_ed25519_sk_rk_YubiKey-USB-A
  IdentityFile ~/.ssh/id_ed25519_sk_rk_Yubikey-USB-C
Host *.h-net.xyz
  User valentin
  CanonicalizeHostname yes
  CanonicalDomains h-net.xyz
  StrictHostKeyChecking no
  IdentityFile ~/.ssh/id_ed25519_sk_rk_YubiKey-USB-A
  IdentityFile ~/.ssh/id_ed25519_sk_rk_Yubikey-USB-C
