Host *
  AddKeysToAgent Yes
  CanonicalDomains h-net.xyz
  CanonicalizeHostname yes
  Compression no
  ForwardAgent yes
  IdentitiesOnly yes
  IdentityAgent ~/.ssh/agent.sock
  ServerAliveInterval 0
  ServerAliveCountMax 3
  StrictHostKeyChecking accept-new
Host github.com
  User git
  HostName github.com
  IdentityFile ~/.ssh/id_ed25519_sk_rk_YubiKey-USB-A
  IdentityFile ~/.ssh/id_ed25519_sk_rk_Yubikey-USB-C
Host gitea.com
  User git
  HostName gitea.com
  IdentityFile ~/.ssh/id_ed25519_sk_rk_YubiKey-USB-A
  IdentityFile ~/.ssh/id_ed25519_sk_rk_Yubikey-USB-C
Host *.h-net.xyz
  User valentin
  IdentityFile ~/.ssh/id_ed25519_sk_rk_YubiKey-USB-A
  IdentityFile ~/.ssh/id_ed25519_sk_rk_Yubikey-USB-C
