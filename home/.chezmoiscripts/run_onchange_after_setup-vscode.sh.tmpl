{{- if and (or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux")) -}}
#!/bin/sh
{{- $extensions := list
     "catppuccin.catppuccin-vsc"
     "waderyan.gitblame"
     "oderwat.indent-rainbow"
     "bbenoist.nix"
     "hashicorp.terraform"
     "tim-koehler.helm-intellisense"
     "openai.chatgpt"
     "github.copilot"
     "github.copilot-chat" }}
{{- $settingsPath := "dot_config/code/settings.json" }}
{{- $settingsHash := include $settingsPath | sha256sum }}

set -euf
SOURCE_SETTINGS="{{ .chezmoi.sourceDir }}/{{ $settingsPath }}"
# Include the source settings hash in the rendered script so chezmoi reruns this
# onchange hook when settings.json changes, even if the script logic stays the same.
# settings.json sha256: {{ $settingsHash }}
case "{{ .chezmoi.os }}" in
  linux)
    TARGET_DIR="$HOME/.config/Code/User"
    ;;
  darwin)
    TARGET_DIR="$HOME/Library/Application Support/Code/User"
    ;;
esac

TARGET_SETTINGS="$TARGET_DIR/settings.json"
mkdir -p "$TARGET_DIR"
cp "$SOURCE_SETTINGS" "$TARGET_SETTINGS"

if ! command -v code >/dev/null 2>&1; then
  exit 0
fi

INSTALLED_EXTENSIONS="$(code --list-extensions 2>/dev/null || true)"
MISSING_EXTENSIONS=""
{{ range $extensions -}}
if ! printf '%s\n' "$INSTALLED_EXTENSIONS" | grep -Fxq -- "{{ . }}"; then
  MISSING_EXTENSIONS="${MISSING_EXTENSIONS} {{ . }}"
fi
{{ end -}}

if [ -z "$MISSING_EXTENSIONS" ]; then
  exit 0
fi

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}"
mkdir -p "$LOG_DIR"

# Install missing extensions in the background so `chezmoi update` doesn't
# block the current terminal session while the VS Code CLI talks to the
# marketplace.
(
  for extension in $MISSING_EXTENSIONS; do
    code --force --install-extension "$extension"
  done
) </dev/null >"$LOG_DIR/chezmoi-vscode-extensions.log" 2>&1 &

{{ end -}}
